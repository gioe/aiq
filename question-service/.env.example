# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aiq_dev
DATABASE_USER=mattgioe
DATABASE_PASSWORD=

# Database URL (for SQLAlchemy)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://mattgioe@localhost:5432/aiq_dev

# Application Settings
ENV=development
DEBUG=True
LOG_LEVEL=INFO

# LLM API Keys
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
XAI_API_KEY=your-xai-api-key-here

# Question Generation Settings
QUESTIONS_PER_RUN=50
MIN_JUDGE_SCORE=0.7

# Judge Configuration
JUDGE_CONFIG_PATH=./config/judges.yaml

# Deduplication Configuration
# Semantic similarity threshold for duplicate detection (0.0-1.0)
# Higher values require closer matches to be considered duplicates
DEDUP_SIMILARITY_THRESHOLD=0.85
# OpenAI embedding model for semantic similarity comparison
DEDUP_EMBEDDING_MODEL=text-embedding-3-small

# Observability - Sentry Error Tracking
# Required for error tracking in production
# ENV (above) is also used as the Sentry environment (development/production)
SENTRY_DSN=
# Release version for Sentry (optional, used for deployment tracking)
RELEASE=

# Observability - OpenTelemetry
# OTLP endpoint for metrics and traces (e.g., Grafana Cloud)
OTEL_EXPORTER_OTLP_ENDPOINT=
# Authentication headers for OTLP endpoint
OTEL_EXPORTER_OTLP_HEADERS=

# Prometheus Metrics Configuration
# Set to false to disable the /metrics endpoint
ENABLE_PROMETHEUS_METRICS=true

# Email (SMTP) Alerts
# Set ENABLE_EMAIL_ALERTS=true and configure SMTP credentials to receive email
# alerts for critical errors (e.g. billing quota exhaustion).
# When enabled, SMTP_PASSWORD, SMTP_USERNAME, and ALERT_TO_EMAILS are required.
# For Gmail, use an App Password (not your account password).
ENABLE_EMAIL_ALERTS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=
ALERT_TO_EMAILS=

# Discord Webhook Alerts
# Set to a Discord webhook URL to receive alerts when circuit breakers open or
# OpenAI quota is exhausted. Leave empty to disable Discord alerts.
DISCORD_WEBHOOK_URL=
