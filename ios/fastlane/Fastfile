default_platform(:ios)

APPLE_KEY_ID = "UCV7S354H2"
APPLE_ISSUER_ID = "69a6de89-0f14-47e3-e053-5b8c7c11a4d1"
APPLE_KEY_PATH = File.expand_path("~/Desktop/keys/AuthKey_UCV7S354H2.p8")

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Load App Store Connect API key"
  lane :load_asc_api_key do
    app_store_connect_api_key(
      key_id: APPLE_KEY_ID,
      issuer_id: APPLE_ISSUER_ID,
      key_filepath: APPLE_KEY_PATH,
      duration: 1200,
      in_house: false
    )
  end

  desc "Create or fetch Apple Distribution certificate"
  lane :create_certificate do
    load_asc_api_key

    get_certificates(generate_apple_certs: true)
  end

  desc "Fetch or create App Store provisioning profile"
  lane :sync_profiles do
    load_asc_api_key

    get_provisioning_profile(
      app_identifier: "com.aiq.app"
    )
  end

  desc "Increment build number (uses latest from App Store Connect)"
  lane :bump_build_number do
    load_asc_api_key

    current_build = latest_testflight_build_number(
      app_identifier: "com.aiq.app"
    )

    increment_build_number(
      build_number: current_build + 1,
      xcodeproj: "AIQ.xcodeproj"
    )
  end

  desc "Build the app for App Store distribution"
  lane :build do |options|
    load_asc_api_key

    get_provisioning_profile(
      app_identifier: "com.aiq.app"
    )

    profile_name = lane_context[SharedValues::SIGH_NAME]

    build_app(
      scheme: "AIQ",
      output_directory: "./build",
      output_name: "AIQ.ipa",
      export_method: "app-store",
      clean: true,
      export_options: {
        signingStyle: "manual",
        teamID: "4HDNC3V5Q6",
        provisioningProfiles: {
          "com.aiq.app" => profile_name
        }
      }
    )
  end

  desc "Upload to TestFlight"
  lane :upload_testflight do
    load_asc_api_key

    upload_to_testflight(
      ipa: "./build/AIQ.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "Capture App Store screenshots on all devices"
  lane :screenshots do
    capture_screenshots
  end

  desc "Add device frames and captions to screenshots"
  lane :frames do
    frame_screenshots(
      path: "./fastlane/screenshots",
      force_device_type: "iPhone 14 Pro Max"
    )
  end

  desc "Capture screenshots, frame them, then upload"
  lane :screenshots_and_upload do
    screenshots
    frames
    upload_metadata
  end

  desc "Upload metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    load_asc_api_key

    deliver(
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_metadata: false,
      skip_screenshots: false,
      skip_binary_upload: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Submit for App Store review (includes metadata + screenshots)"
  lane :submit_review do
    load_asc_api_key

    deliver(
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_metadata: false,
      skip_screenshots: false,
      submission_information: {
        add_id_info_uses_idfa: false
      },
      precheck_include_in_app_purchases: false
    )
  end

  desc "Full pipeline: screenshots, bump build, build, upload, and submit for review"
  lane :release do
    screenshots
    frames
    bump_build_number
    build
    upload_testflight
    submit_review
    tag_release
  end

  desc "Build and upload to TestFlight with metadata and screenshots"
  lane :beta do
    bump_build_number
    build
    upload_testflight
    upload_metadata
    tag_release
  end

  desc "Tag the current commit with v{version}-{build}"
  lane :tag_release do
    version = get_version_number(xcodeproj: "AIQ.xcodeproj", target: "AIQ")
    build_num = get_build_number(xcodeproj: "AIQ.xcodeproj")
    tag = "v#{version}-#{build_num}"

    if git_tag_exists(tag: tag)
      UI.important("Tag #{tag} already exists, skipping")
    else
      add_git_tag(tag: tag)
      push_git_tags(tag: tag)
      UI.success("Tagged #{tag}")
    end
  end

  desc "Generate release notes from commits since the last tag"
  lane :generate_release_notes do
    tag = last_git_tag
    if tag.nil? || tag.empty?
      UI.important("No previous tag found — using full log")
      log = changelog_from_git_commits(commits_count: 50, pretty: "- %s")
    else
      log = changelog_from_git_commits(between: [tag, "HEAD"], pretty: "- %s")
    end
    log
  end
end
